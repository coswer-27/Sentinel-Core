# === 服務 URL（api-gateway 使用） ===
NLP_SERVICE_URL=http://127.0.0.1:8001/analyze
URL_SERVICE_URL=http://127.0.0.1:8002/analyze/links

# === Google Safe Browsing API Key（service_link_scanner 使用） ===
#
# 用途：
#   呼叫 Google Safe Browsing Lookup API v4，
#   即時判斷 URL 是否已被 Google 標記為惡意網址。
#   Key 作為 query parameter 附加於每個請求：
#     POST https://safebrowsing.googleapis.com/v4/threatMatches:find?key=YOUR_KEY
#
# 申請步驟：
#   1. 前往 https://console.cloud.google.com，建立或選擇一個 GCP 專案
#   2. 「APIs & Services」>「Library」搜尋「Safe Browsing API」> 啟用
#   3. 「APIs & Services」>「Credentials」>「Create Credentials」>「API Key」
#   4. 複製產生的 Key，貼入下方變數
#   完整說明：https://developers.google.com/safe-browsing/v4/get-started
#
# 官方測試 URL（設好 Key 後可用 /analyze/links 端點驗證回傳結果）：
#   http://testsafebrowsing.appspot.com  
GOOGLE_SAFE_BROWSING_API_KEY=your_key_here

# === 限流設定（api-gateway 使用） ===
GATEWAY_RATE_LIMIT="5/second"

# VirusTotal（預留，此版本暫未實作）
# VIRUSTOTAL_API_KEY=your_key_here

# WhoisXML（預留，此版本暫未實作）
# WHOISXML_API_KEY=your_key_here
